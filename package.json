{
  "name": "@amerilux/netsuite-repository",
  "version": "0.1.0",
  "private": false,
  "description": "Typed query configuration and record update helpers for NetSuite SuiteScript.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./query": {
      "types": "./dist/query.d.ts",
      "default": "./dist/query.js"
    },
    "./record-updater": {
      "types": "./dist/record-updater.d.ts",
      "default": "./dist/record-updater.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "default": "./dist/context.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack": "npm pack",
    "pack:dry-run": "npm pack --dry-run",
    "publish:npm": "npm publish",
    "packAndPublish": "npm run build && npm run test && npm publish",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@hitc/netsuite-types": "2025.1.11",
    "@nizos/probity": "^1.5.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "5.8.3"
  },
  "publishConfig": {
    "tag": "latest",
    "access": "public"
  }
}
