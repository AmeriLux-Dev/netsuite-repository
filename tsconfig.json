{
  "compilerOptions": {
    "target": "es2019",
    "module": "commonjs",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "N/*": ["./node_modules/@hitc/netsuite-types/N/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/__tests__/**", "src/__mocks__/**"]
}